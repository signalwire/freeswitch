{
    "files.eol": "auto", // Keeps the original line endings (LF or CRLF) as they are
    "files.trimTrailingWhitespace": false, // Does not remove spaces at the end of lines
    "files.insertFinalNewline": false, // Does not add a new blank line at the end of the file
    "files.trimFinalNewlines": false, // Does not remove existing blank lines at the end of the file
    "editor.formatOnSave": false, // Disables automatic code formatting when saving
    "editor.formatOnType": false, // Disables formatting while typing
    "editor.formatOnPaste": false, // Disables formatting when pasting code
    "editor.codeActionsOnSave": {
        "source.fixAll": false // Disables all auto-fixes on save
    }
}